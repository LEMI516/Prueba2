<fragment>
  <rate-limit-by-key calls="{{rate-calls}}" renewal-period="{{rate-period-seconds}}"
    counter-key="@(context.Subscription?.Key ?? context.Request.IpAddress)" />

  <quota-by-key calls="{{quota-calls}}" renewal-period="{{quota-period-seconds}}"
    counter-key="@(context.Subscription?.Key ?? context.Request.IpAddress)" />
</fragment>
